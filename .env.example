# === MODE ===
NEXT_PUBLIC_DEMO_MODE=true  # Set to false for live API connections

# === Authentication (optional — leave empty for demo mode) ===
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=generate-a-random-32-char-string
AUTH_MICROSOFT_ENTRA_ID_ID=your-app-client-id
AUTH_MICROSOFT_ENTRA_ID_SECRET=your-app-client-secret
# Restrict to your tenant (recommended). Use one of the two options below:
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=your-tenant-id
# Or set the full issuer URL directly (takes precedence over TENANT_ID):
# AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/your-tenant-id/v2.0/
# Set AUTH_URL to your Vercel deployment URL in production (not needed locally)
# AUTH_URL=https://your-app.vercel.app

# === Business Central ===
BC_TENANT_ID=your-tenant-guid
BC_CLIENT_ID=your-app-client-id
BC_CLIENT_SECRET=your-client-secret
BC_ENVIRONMENT=production  # or "sandbox"

# === Microsoft Graph (same app registration) ===
# Uses same BC_TENANT_ID, BC_CLIENT_ID, BC_CLIENT_SECRET

# === Azure Cost Management (optional) ===
AZURE_SUBSCRIPTION_ID=your-subscription-id

# === Officient HR (optional) ===
# Pick ONE auth option:
#  A) Personal API token (simplest) — generate at https://app.officient.io/developer
OFFICIENT_API_TOKEN=
#  B) OAuth2 app credentials (token is fetched + cached automatically)
OFFICIENT_CLIENT_ID=your-officient-client-id
OFFICIENT_CLIENT_SECRET=your-officient-client-secret
# Override only if your tenant uses a different token endpoint:
# OFFICIENT_TOKEN_URL=https://api.officient.io/1.0/token

# === Jira (optional) ===
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
# Blended hourly cost (EUR) used to value worklog time. Default 75.
JIRA_HOURLY_COST=75

# === Dell Warranty (optional) ===
DELL_CLIENT_ID=your-dell-techdirect-client-id
DELL_CLIENT_SECRET=your-dell-techdirect-client-secret

# === Lenovo Warranty (optional) ===
LENOVO_CLIENT_ID=your-lenovo-esupport-client-id

# === Samsung Knox (optional) ===
KNOX_CLIENT_ID=your-knox-client-id
KNOX_CLIENT_SECRET=your-knox-client-secret

# === AI Chat ===
GOOGLE_GENERATIVE_AI_API_KEY=           # Free — get from aistudio.google.com

# === Database (optional — durable, multi-user persistence) ===
# When set, settings (GL mappings, license prices), EasyPay payroll and software
# licenses persist to Postgres instead of local JSON files. Schema auto-creates.
# Leave empty for demo/local (file + in-memory stores).
DATABASE_URL=                           # postgres://user:pass@host:5432/itfinance?sslmode=require
# TLS: "verify-full" (set PGSSLROOTCERT to the CA path) or "require" (encrypt only)
DATABASE_SSL=
PGSSLROOTCERT=                          # e.g. /etc/ssl/postgres-ca/ca.crt (verify-full)
# DATABASE_POOL_MAX=10

# === Sync ===
SYNC_CRON_SECRET=                       # Protects POST /api/sync and the automated EasyPay drop — openssl rand -base64 32

# === EasyPay payroll (no API — CSV/TXT import) ===
# EasyPay Group is a Belgian social secretariat with no public API. Export your IT
# department's monthly payroll from EASY online and either upload it on the Import
# page, or POST it automatically:
#   curl -X POST https://host/api/import/easypay -H "Authorization: Bearer $SYNC_CRON_SECRET" \
#        -H "Content-Type: text/csv" --data-binary @easypay-march.csv
# Persisted to data/easypay-payroll.json — mount the data/ dir as a volume to keep it.
# PAYROLL_DATA_DIR=/data                 # Override the storage directory (default: ./data)
