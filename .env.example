# === MODE ===
NEXT_PUBLIC_DEMO_MODE=true  # Set to false for live API connections

# === Business Central ===
BC_TENANT_ID=your-tenant-guid
BC_CLIENT_ID=your-app-client-id
BC_CLIENT_SECRET=your-client-secret
BC_ENVIRONMENT=production  # or "sandbox"

# === Microsoft Graph (same app registration) ===
# Uses same BC_TENANT_ID, BC_CLIENT_ID, BC_CLIENT_SECRET

# === Azure Cost Management (optional) ===
AZURE_SUBSCRIPTION_ID=your-subscription-id

# === App Settings ===
SYNC_CRON_SECRET=random-secret-for-cron-auth
