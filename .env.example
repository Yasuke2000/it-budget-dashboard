# === MODE ===
NEXT_PUBLIC_DEMO_MODE=true  # Set to false for live API connections

# === Authentication (optional — leave empty for demo mode) ===
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=generate-a-random-32-char-string
AUTH_MICROSOFT_ENTRA_ID_ID=your-app-client-id
AUTH_MICROSOFT_ENTRA_ID_SECRET=your-app-client-secret
# Restrict to your tenant (recommended). Use one of the two options below:
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=your-tenant-id
# Or set the full issuer URL directly (takes precedence over TENANT_ID):
# AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/your-tenant-id/v2.0/
# Set AUTH_URL to your Vercel deployment URL in production (not needed locally)
# AUTH_URL=https://your-app.vercel.app

# === Business Central ===
BC_TENANT_ID=your-tenant-guid
BC_CLIENT_ID=your-app-client-id
BC_CLIENT_SECRET=your-client-secret
BC_ENVIRONMENT=production  # or "sandbox"

# === Microsoft Graph (same app registration) ===
# Uses same BC_TENANT_ID, BC_CLIENT_ID, BC_CLIENT_SECRET

# === Azure Cost Management (optional) ===
AZURE_SUBSCRIPTION_ID=your-subscription-id

# === Officient HR (optional) ===
OFFICIENT_CLIENT_ID=your-officient-client-id
OFFICIENT_CLIENT_SECRET=your-officient-client-secret

# === Jira (optional) ===
JIRA_BASE_URL=https://gheeraertportal.atlassian.net
JIRA_EMAIL=your-email@gheeraert.be
JIRA_API_TOKEN=your-jira-api-token

# === Dell Warranty (optional) ===
DELL_CLIENT_ID=your-dell-techdirect-client-id
DELL_CLIENT_SECRET=your-dell-techdirect-client-secret

# === Lenovo Warranty (optional) ===
LENOVO_CLIENT_ID=your-lenovo-esupport-client-id

# === Samsung Knox (optional) ===
KNOX_CLIENT_ID=your-knox-client-id
KNOX_CLIENT_SECRET=your-knox-client-secret

# === AI Chat (optional) ===
GOOGLE_GENERATIVE_AI_API_KEY=   # Free — get from aistudio.google.com. Enables AI chat. Without it, demo responses.

# === App Settings ===
SYNC_CRON_SECRET=random-secret-for-cron-auth
